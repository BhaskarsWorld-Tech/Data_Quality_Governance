  {
    "id": "spec_br_001", "name": "Order Net = Total - Discount + Tax", "description": "NET_AMOUNT should equal TOTAL_AMOUNT - DISCOUNT_AMOUNT + TAX_AMOUNT",
    "category": "accuracy", "type": "business_rule_check", "connectionId": "conn_1778038927683_6wexdmvm5",
    "tableName": "SALES_ORDERS", "parameters": { "sql": "SELECT COUNT(*) FROM SALES_ORDERS WHERE ABS(NET_AMOUNT - (TOTAL_AMOUNT - DISCOUNT_AMOUNT + TAX_AMOUNT)) > 0.01" },
    "enabled": true, "status": "active", "severity": "critical", "scope": "object-specific", "createdAt": "2026-05-01T00:00:00Z"
  },
  {
    "id": "spec_br_002", "name": "Shipped Date After Order Date", "description": "SHIPPED_DATE must be on or after ORDER_DATE",
    "category": "accuracy", "type": "business_rule_check", "connectionId": "conn_1778038927683_6wexdmvm5",
    "tableName": "SALES_ORDERS", "parameters": { "sql": "SELECT COUNT(*) FROM SALES_ORDERS WHERE SHIPPED_DATE IS NOT NULL AND SHIPPED_DATE < ORDER_DATE" },
    "enabled": true, "status": "active", "severity": "high", "scope": "object-specific", "createdAt": "2026-05-01T00:00:00Z"
  },
  {
    "id": "spec_br_003", "name": "PO Item Total = Qty × Unit Price", "description": "TOTAL_PRICE should equal QUANTITY × UNIT_PRICE",
    "category": "accuracy", "type": "business_rule_check", "connectionId": "conn_1778038927683_6wexdmvm5",
    "tableName": "PURCHASE_ORDER_ITEMS", "parameters": { "sql": "SELECT COUNT(*) FROM PURCHASE_ORDER_ITEMS WHERE ABS(TOTAL_PRICE - QUANTITY * UNIT_PRICE) > 0.01" },
    "enabled": true, "status": "active", "severity": "critical", "scope": "object-specific", "createdAt": "2026-05-01T00:00:00Z"
  },
  {
    "id": "spec_br_004", "name": "Cost < Price Margin Check", "description": "Product UNIT_COST should be less than UNIT_PRICE",
    "category": "accuracy", "type": "business_rule_check", "connectionId": "conn_1778038927683_6wexdmvm5",
    "tableName": "PRODUCTS", "parameters": { "sql": "SELECT COUNT(*) FROM PRODUCTS WHERE UNIT_COST >= UNIT_PRICE AND UNIT_PRICE > 0" },
    "enabled": true, "status": "active", "severity": "high", "scope": "object-specific", "createdAt": "2026-05-01T00:00:00Z"
  },
  {
    "id": "spec_br_005", "name": "Return Date After Order Date", "description": "RETURN_DATE must be after the original ORDER_DATE",
    "category": "accuracy", "type": "business_rule_check", "connectionId": "conn_1778038927683_6wexdmvm5",
    "tableName": "RETURNS", "parameters": { "sql": "SELECT COUNT(*) FROM RETURNS r JOIN SALES_ORDERS o ON r.ORDER_ID = o.ORDER_ID WHERE r.RETURN_DATE < o.ORDER_DATE" },
    "enabled": true, "status": "active", "severity": "medium", "scope": "object-specific", "createdAt": "2026-05-01T00:00:00Z"
  },
  {
    "id": "spec_br_006", "name": "Discount ≤ Total Amount", "description": "DISCOUNT_AMOUNT should not exceed TOTAL_AMOUNT",
